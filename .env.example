MYSQL_ROOT_PASSWORD=your_root_password
MYSQL_DATABASE=construction_log
MYSQL_USER=construction_user
MYSQL_PASSWORD=your_password

# Подключение к БД из бэкенд-контейнера
DATABASE_URL=mysql://construction_user:your_password@db:3306/construction_log

# Порт для API
PORT=3001

# Разрешённые origins для CORS (через запятую, для продакшена)
# CORS_ORIGIN=https://your-domain.com
